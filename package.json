{
  "name": "calibrate",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173",
    "dev:gds": "vite --mode gds --port 5174",
    "dev:all": "concurrently -n me,gds -c green,blue \"npm run dev\" \"npm run dev:gds\"",
    "build": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "build:pages": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && node scripts/build-pages.mjs",
    "preview": "vite preview",
    "test:pod": "node scripts/test-pod.mjs"
  },
  "dependencies": {
    "@inrupt/solid-client": "^3.0.0",
    "@inrupt/solid-client-authn-browser": "^3.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.3.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "typescript": "^5.8.2",
    "vite": "^6.2.0"
  }
}
